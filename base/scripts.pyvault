    {
      "code": "#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\nПрограмма для удаления временных файлов Windows\nТребует права администратора для полноценной работы\n\"\"\"\n\nimport os\nimport sys\nimport shutil\nimport ctypes\nimport tkinter as tk\nfrom tkinter import ttk, messagebox, filedialog\nfrom threading import Thread\nimport time\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nimport queue\nimport webbrowser\nimport configparser\nimport json\n\n# Функция для поиска ресурсов (работает и в exe, и в py)\ndef resource_path(relative_path):\n    if hasattr(sys, '_MEIPASS'):\n        return os.path.join(sys._MEIPASS, relative_path)\n    return os.path.join(os.path.abspath(os.path.dirname(__file__)), relative_path)\n\nclass IconTk(tk.Tk):\n    def __init__(self, *args, **kwargs):\n        super().__init__(*args, **kwargs)\n        self.overrideredirect(True)  # Убираем рамку окна\n        self.geometry(\"0x0\")  # Устанавливаем нулевой размер\n        self.setup_icon()\n        self.overrideredirect(False)  # Возвращаем рамку\n    \n    def setup_icon(self):\n        icon_path_ico = resource_path('icon.ico')\n        icon_path_png = resource_path('icon.png')\n        try:\n            if os.path.exists(icon_path_ico):\n                self.iconbitmap(icon_path_ico)\n            elif os.path.exists(icon_path_png):\n                icon_img = tk.PhotoImage(file=icon_path_png)\n                self.iconphoto(True, icon_img)\n        except Exception as e:\n            pass\n\nclass IconToplevel(tk.Toplevel):\n    def __init__(self, *args, **kwargs):\n        super().__init__(*args, **kwargs)\n        self.setup_icon()\n    \n    def setup_icon(self):\n        icon_path_ico = resource_path('icon.ico')\n        icon_path_png = resource_path('icon.png')\n        try:\n            if os.path.exists(icon_path_ico):\n                self.iconbitmap(icon_path_ico)\n            elif os.path.exists(icon_path_png):\n                icon_img = tk.PhotoImage(file=icon_path_png)\n                self.iconphoto(True, icon_img)\n        except Exception as e:\n            pass\n\nclass ConfigManager:\n    def __init__(self):\n        self.config_file = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'config.ini')\n        self.config = configparser.ConfigParser()\n        self.load_config()\n    \n    def load_config(self):\n        if os.path.exists(self.config_file):\n            self.config.read(self.config_file, encoding='utf-8')\n        if 'Windows' not in self.config:\n            self.config['Windows'] = {}\n    \n    def save_config(self):\n        with open(self.config_file, 'w', encoding='utf-8') as f:\n            self.config.write(f)\n    \n    def get_window_geometry(self, window_name):\n        if window_name in self.config['Windows']:\n            try:\n                return json.loads(self.config['Windows'][window_name])\n            except:\n                pass\n        return None\n    \n    def save_window_geometry(self, window_name, geometry):\n        try:\n            self.config['Windows'][window_name] = json.dumps(geometry)\n            self.save_config()\n        except Exception as e:\n            pass\n\nclass TempCleaner:\n    def __init__(self):\n        self.lists_dir = resource_path('userlists')\n        os.makedirs(self.lists_dir, exist_ok=True)\n        self.ini_file = os.path.join(self.lists_dir, 'active_list.ini')\n        self.config_file = self.get_last_active_list()\n        self.paths_data = {}\n        self.calculation_queue = queue.Queue()\n        self.executor = ThreadPoolExecutor(max_workers=4)\n        self.load_config()\n        \n        # Добавляем отслеживание окна редактора\n        self.editor_window = None\n        self.editor_text = None\n        self.editor_has_changes = False\n        \n        if not self.is_admin():\n            self.run_as_admin()\n            sys.exit()\n        \n        self.setup_gui()\n        self.start_background_calculator()\n    \n    def is_admin(self):\n        try:\n            return ctypes.windll.shell32.IsUserAnAdmin()\n        except:\n            return False\n    \n    def run_as_admin(self):\n        try:\n            ctypes.windll.shell32.ShellExecuteW(None, \"runas\", sys.executable, __file__, None, 1)\n        except:\n            messagebox.showerror(\"Ошибка\", \"Не удалось запустить программу от имени администратора\")\n    \n    def load_config(self):\n        try:\n            self.paths_data.clear()\n            if os.path.exists(self.config_file):\n                with open(self.config_file, 'r', encoding='utf-8') as f:\n                    for line in f:\n                        line = line.strip()\n                        if line and '|' in line:\n                            parts = line.split('|', 2)\n                            if len(parts) >= 2:\n                                path = parts[0]\n                                enabled = parts[1] == '+'\n                                comment = parts[2] if len(parts) > 2 else \"\"\n                                # Извлекаем скрытую заметку из комментария\n                                hidden_note = \"\"\n                                if \"(\" in comment and \")\" in comment:\n                                    start = comment.find(\"(\")\n                                    end = comment.find(\")\")\n                                    if start != -1 and end != -1 and end > start:\n                                        hidden_note = comment[start+1:end].strip()\n                                        comment = (comment[:start] + comment[end+1:]).strip()\n                                self.paths_data[path] = {\n                                    'enabled': enabled, \n                                    'comment': comment, \n                                    'hidden_note': hidden_note,\n                                    'size': 0, \n                                    'count': 0\n                                }\n        except Exception as e:\n            pass\n    \n    def save_config(self):\n        try:\n            with open(self.config_file, 'w', encoding='utf-8') as f:\n                for path, data in self.paths_data.items():\n                    status = '+' if data['enabled'] else '-'\n                    comment = data['comment']\n                    if data['hidden_note']:\n                        comment = f\"{comment} ({data['hidden_note']})\"\n                    f.write(f\"{path}|{status}|{comment}\\n\")\n        except Exception as e:\n            pass\n    \n    def expand_windows_path(self, path):\n        \"\"\"Раскрывает переменные окружения Windows в пути\"\"\"\n        try:\n            # Убираем звездочки в конце пути\n            clean_path = path.rstrip('*')\n            \n            # Заменяем %VAR% на реальные значения\n            expanded = os.path.expandvars(clean_path)\n            \n            # Обработка специальных случаев\n            if '%WINDIR%' in clean_path:\n                expanded = expanded.replace('%WINDIR%', os.environ.get('WINDIR', 'C:\\\\Windows'))\n            if '%TEMP%' in clean_path:\n                expanded = expanded.replace('%TEMP%', os.environ.get('TEMP', ''))\n            if '%TMP%' in clean_path:\n                expanded = expanded.replace('%TMP%', os.environ.get('TMP', ''))\n            if '%LOCALAPPDATA%' in clean_path:\n                expanded = expanded.replace('%LOCALAPPDATA%', os.environ.get('LOCALAPPDATA', ''))\n            if '%APPDATA%' in clean_path:\n                expanded = expanded.replace('%APPDATA%', os.environ.get('APPDATA', ''))\n            if '%USERPROFILE%' in clean_path:\n                expanded = expanded.replace('%USERPROFILE%', os.environ.get('USERPROFILE', ''))\n            if '%PROGRAMDATA%' in clean_path:\n                expanded = expanded.replace('%PROGRAMDATA%', os.environ.get('PROGRAMDATA', ''))\n            if '%PROGRAMFILES%' in clean_path:\n                expanded = expanded.replace('%PROGRAMFILES%', os.environ.get('PROGRAMFILES', ''))\n            if '%PROGRAMFILES(X86)%' in clean_path:\n                expanded = expanded.replace('%PROGRAMFILES(X86)%', os.environ.get('PROGRAMFILES(X86)', ''))\n            if '%SYSTEMROOT%' in clean_path:\n                expanded = expanded.replace('%SYSTEMROOT%', os.environ.get('SYSTEMROOT', ''))\n            if '%SYSTEMDRIVE%' in clean_path:\n                expanded = expanded.replace('%SYSTEMDRIVE%', os.environ.get('SYSTEMDRIVE', ''))\n            \n            # Если путь заканчивался звездочкой, добавляем её обратно\n            if path.endswith('*'):\n                expanded = expanded + '*'\n            \n            return expanded\n        except Exception:\n            return path\n\n    def calculate_temp_files(self, path):\n        total_size = file_count = 0\n        try:\n            # Раскрываем переменные окружения в пути\n            expanded_path = self.expand_windows_path(path)\n            if not os.path.exists(expanded_path):\n                return total_size, file_count\n            \n            # Если путь заканчивается звездочкой, обрабатываем все файлы в директории\n            if expanded_path.endswith('*'):\n                expanded_path = expanded_path[:-1]  # Убираем звездочку\n                if not os.path.exists(expanded_path):\n                    return total_size, file_count\n                \n                # Обрабатываем все файлы в директории\n                for root, dirs, files in os.walk(expanded_path, followlinks=False):\n                    dirs[:] = [d for d in dirs if not os.path.islink(os.path.join(root, d))]\n                    for file in files:\n                        try:\n                            file_path = os.path.join(root, file)\n                            if not os.path.islink(file_path) and os.path.exists(file_path):\n                                total_size += os.path.getsize(file_path)\n                                file_count += 1\n                        except (OSError, PermissionError):\n                            continue\n            else:\n                # Обрабатываем конкретный путь\n                for root, dirs, files in os.walk(expanded_path, followlinks=False):\n                    dirs[:] = [d for d in dirs if not os.path.islink(os.path.join(root, d))]\n                    for file in files:\n                        try:\n                            file_path = os.path.join(root, file)\n                            if not os.path.islink(file_path) and os.path.exists(file_path):\n                                total_size += os.path.getsize(file_path)\n                                file_count += 1\n                        except (OSError, PermissionError):\n                            continue\n        except (OSError, PermissionError):\n            pass\n        return total_size, file_count\n    \n    def calculate_temp_files_async(self, path):\n        try:\n            size, count = self.calculate_temp_files(path)\n            return path, size, count\n        except Exception:\n            return path, 0, 0\n    \n    def start_background_calculator(self):\n        def calculator_worker():\n            while True:\n                try:\n                    if not self.calculation_queue.empty():\n                        paths_to_calculate = []\n                        while not self.calculation_queue.empty():\n                            try:\n                                path = self.calculation_queue.get_nowait()\n                                if path not in paths_to_calculate:\n                                    paths_to_calculate.append(path)\n                            except queue.Empty:\n                                break\n                        \n                        if paths_to_calculate:\n                            self.update_status(\"Вычисление размеров папок...\")\n                            futures = {self.executor.submit(self.calculate_temp_files_async, path): path for path in paths_to_calculate}\n                            \n                            for i, future in enumerate(as_completed(futures)):\n                                path, size, count = future.result()\n                                if path in self.paths_data:\n                                    self.paths_data[path]['size'] = size\n                                    self.paths_data[path]['count'] = count\n                                self.update_status(f\"Вычисление: {i + 1}/{len(paths_to_calculate)}\")\n                                self.root.after(0, self.update_single_path_display, path)\n                            \n                            self.update_status(\"Готово\")\n                            self.root.after(0, self.update_disk_info)\n                            self.root.after(0, self.update_totals)\n                    \n                    time.sleep(0.1)\n                except Exception as e:\n                    self.update_status(f\"Ошибка: {str(e)}\")\n                    time.sleep(1)\n        \n        Thread(target=calculator_worker, daemon=True).start()\n    \n    def queue_calculation(self, path):\n        self.calculation_queue.put(path)\n    \n    def update_status(self, message):\n        self.root.after(0, lambda: self.status_var.set(message))\n    \n    def update_single_path_display(self, path):\n        if path not in self.paths_data:\n            return\n        \n        data = self.paths_data[path]\n        for item in self.paths_tree.get_children():\n            values = self.paths_tree.item(item, 'values')\n            if values[2] == path:\n                status_text = \" ✅ Очистить\" if data['enabled'] else \" ❎ Не очищать\"\n                self.paths_tree.item(item, values=(\n                    status_text, data['comment'], path, self.format_size(data['size']),\n                    data['count']\n                ), tags=('enabled',) if data['enabled'] else ('disabled',))\n                break\n    \n    def update_totals(self):\n        total_size = total_files = 0\n        for data in self.paths_data.values():\n            if data['enabled']:\n                total_size += data['size']\n                total_files += data['count']\n        \n        self.total_size_label.config(text=f\"Общий объем: {self.format_size(total_size)}\")\n        self.total_files_label.config(text=f\"Файлов: {total_files}\")\n    \n    def format_size(self, size_bytes):\n        if size_bytes == 0:\n            return \"0 B\"\n        for unit in ['B', 'KB', 'MB', 'GB', 'TB']:\n            if size_bytes < 1024.0:\n                return f\"{size_bytes:.1f} {unit}\"\n            size_bytes /= 1024.0\n        return f\"{size_bytes:.1f} PB\"\n    \n    def update_disk_info(self):\n        disks_info = {}\n        temp_files_by_disk = {}\n        total_to_delete = 0\n        for path, data in self.paths_data.items():\n            if not data['enabled']:\n                continue\n            try:\n                # Исправляем определение диска\n                if os.path.isabs(path):\n                    drive = os.path.splitdrive(path)[0] + os.sep\n                else:\n                    drive = os.path.splitdrive(os.path.abspath(path))[0] + os.sep\n                if drive and os.path.exists(drive):\n                    if drive not in disks_info:\n                        total, used, free = shutil.disk_usage(drive)\n                        disks_info[drive] = {'total': total, 'used': used, 'free': free}\n                        temp_files_by_disk[drive] = 0\n                    temp_files_by_disk[drive] += data['size']\n                    total_to_delete += data['size']\n            except Exception as e:\n                pass\n        for item in self.disk_tree.get_children():\n            self.disk_tree.delete(item)\n        for drive, info in disks_info.items():\n            total, used = info['total'], info['used']\n            temp_size = temp_files_by_disk.get(drive, 0)\n            used_without_temp = used - temp_size\n            free_after_cleanup = info['free'] + temp_size\n            used_percent = (used_without_temp / total) * 100\n            temp_percent = (temp_size / total) * 100\n            free_percent = (free_after_cleanup / total) * 100\n            self.disk_tree.insert('', 'end', values=(\n                drive, self.format_size(total), f\"{used_percent:.1f}%\",\n                f\"{temp_percent:.1f}%\", f\"{free_percent:.1f}%\", self.format_size(temp_size)\n            ))\n        # Обновляю надпись справа\n        if hasattr(self, 'label_total_to_delete'):\n            self.label_total_to_delete.config(text=self.format_size(total_to_delete))\n    \n    def update_paths_info(self):\n        self.paths_tree.delete(*self.paths_tree.get_children())\n        \n        for path, data in self.paths_data.items():\n            status_text = \" ✅ Очистить\" if data['enabled'] else \" ❎ Не очищать\"\n            size_text = self.format_size(data['size']) if data['size'] > 0 else \"Вычисляется...\"\n            count_text = str(data['count']) if data['size'] > 0 else \"...\"\n            \n            self.paths_tree.insert('', 'end', values=(\n                status_text, data['comment'], path, size_text, count_text\n            ), tags=('enabled',) if data['enabled'] else ('disabled',))\n            \n            if data['size'] == 0:\n                self.queue_calculation(path)\n        \n        self.update_totals()\n    \n    def sort_column(self, col, reverse):\n        data = []\n        for child in self.paths_tree.get_children(''):\n            values = self.paths_tree.item(child, 'values')\n            path = values[2]\n            if path in self.paths_data:\n                # Сохраняем оригинальные данные для сортировки\n                data.append((values, child, self.paths_data[path]))\n        \n        try:\n            if col == '#4':  # Размер\n                data.sort(key=lambda x: self.parse_size(x[0][3]), reverse=reverse)\n            elif col == '#3':  # Путь\n                data.sort(key=lambda x: x[0][2].lower(), reverse=reverse)\n            elif col == '#5':  # Файлов\n                data.sort(key=lambda x: int(x[0][4]) if x[0][4].isdigit() else 0, reverse=reverse)\n            else:\n                data.sort(key=lambda x: x[0][int(col[1:])-1], reverse=reverse)\n        except:\n            data.sort(reverse=reverse)\n        \n        # Перемещаем элементы в новом порядке\n        for index, (_, child, _) in enumerate(data):\n            self.paths_tree.move(child, '', index)\n        \n        # Обновляем порядок в paths_data\n        new_order = {}\n        for child in self.paths_tree.get_children():\n            values = self.paths_tree.item(child, 'values')\n            path = values[2]\n            if path in self.paths_data:\n                new_order[path] = self.paths_data[path]\n        \n        self.paths_data = new_order\n        self.save_config()\n        self.paths_tree.heading(col, command=lambda: self.sort_column(col, not reverse))\n    \n    def parse_size(self, size_str):\n        if size_str == \"Вычисляется...\":\n            return 0\n        try:\n            parts = size_str.split()\n            if len(parts) == 2:\n                num, unit = float(parts[0]), parts[1]\n                multipliers = {'B': 1, 'KB': 1024, 'MB': 1024**2, 'GB': 1024**3, 'TB': 1024**4}\n                return num * multipliers.get(unit, 1)\n        except:\n            pass\n        return 0\n    \n    def on_path_click(self, event):\n        item = self.paths_tree.identify_row(event.y)\n        if not item:\n            return\n        \n        column = self.paths_tree.identify_column(event.x)\n        values = self.paths_tree.item(item, 'values')\n        path = values[2]\n        \n        if column == '#1':\n            if path in self.paths_data:\n                self.paths_data[path]['enabled'] = not self.paths_data[path]['enabled']\n                self.save_config()\n                self.refresh_info()\n    \n    def on_path_double_click(self, event):\n        item = self.paths_tree.identify_row(event.y)\n        if not item:\n            return\n        column = self.paths_tree.identify_column(event.x)\n        values = self.paths_tree.item(item, 'values')\n        path = values[2]\n        if column == '#2':\n            self.edit_comment_inline(event, item, path)\n    \n    def edit_comment_inline(self, event, item, path):\n        if path not in self.paths_data:\n            return\n        \n        current_comment = self.paths_data[path]['comment']\n        \n        edit_window = IconToplevel(self.root)\n        edit_window.title(\"Редактирование комментария\")\n        edit_window.geometry(\"400x100\")\n        edit_window.transient(self.root)\n        edit_window.grab_set()\n        \n        tk.Label(edit_window, text=\"Комментарий:\").pack(pady=5)\n        \n        entry = tk.Entry(edit_window, width=50)\n        entry.pack(pady=5, padx=10, fill='x')\n        entry.insert(0, current_comment)\n        entry.select_range(0, tk.END)\n        entry.focus()\n        \n        def copy_text():\n            self.root.clipboard_clear()\n            self.root.clipboard_append(entry.get())\n        \n        def paste_text():\n            try:\n                clipboard_text = self.root.clipboard_get()\n                entry.delete(0, tk.END)\n                entry.insert(0, clipboard_text)\n            except:\n                pass\n        \n        def save_comment():\n            self.paths_data[path]['comment'] = entry.get()\n            self.save_config()\n            edit_window.destroy()\n            self.refresh_info()\n        \n        def cancel_edit():\n            edit_window.destroy()\n        \n        button_frame = tk.Frame(edit_window)\n        button_frame.pack(pady=10)\n        \n        tk.Button(button_frame, text=\"Копировать\", command=copy_text).pack(side='left', padx=5)\n        tk.Button(button_frame, text=\"Вставить\", command=paste_text).pack(side='left', padx=5)\n        tk.Button(button_frame, text=\"Сохранить\", command=save_comment).pack(side='left', padx=5)\n        tk.Button(button_frame, text=\"Отмена\", command=cancel_edit).pack(side='left', padx=5)\n        \n        entry.bind('<Return>', lambda e: save_comment())\n        entry.bind('<Escape>', lambda e: cancel_edit())\n        edit_window.protocol(\"WM_DELETE_WINDOW\", cancel_edit)\n    \n    def toggle_all_paths(self, enable=True):\n        \"\"\"Включить или выключить все пути\"\"\"\n        for path in self.paths_data:\n            self.paths_data[path]['enabled'] = enable\n        self.save_config()\n        self.refresh_info()\n    \n    def open_telegram(self):\n        \"\"\"Открыть телеграм разработчика\"\"\"\n        webbrowser.open(\"https://t.me/Var_production\")\n    \n    def add_custom_path(self):\n        path = filedialog.askdirectory(title=\"Выберите папку для очистки\")\n        if path and path not in self.paths_data:\n            self.paths_data[path] = {'enabled': True, 'comment': '', 'size': 0, 'count': 0}\n            self.save_config()\n            self.refresh_info()\n    \n    def remove_custom_path(self):\n        selection = self.paths_tree.selection()\n        if not selection:\n            messagebox.showwarning(\"Предупреждение\", \"Выберите путь для удаления\")\n            return\n        \n        values = self.paths_tree.item(selection[0], 'values')\n        path = values[2]\n        \n        # Добавляем подтверждение удаления\n        if not messagebox.askyesno(\"Подтверждение\", f\"Вы действительно хотите удалить путь?\\n{path}\"):\n            return\n        \n        if path in self.paths_data:\n            del self.paths_data[path]\n            self.save_config()\n            self.refresh_info()\n    \n    def clean_temp_files(self):\n        enabled_paths = [path for path, data in self.paths_data.items() if data['enabled']]\n        if not enabled_paths:\n            messagebox.showwarning(\"Предупреждение\", \"Нет активных путей для очистки\")\n            return\n            \n        if not messagebox.askyesno(\"Подтверждение\", \"Вы уверены, что хотите удалить временные файлы?\"):\n            return\n        \n        self.progress_bar.grid(row=4, column=0, columnspan=3, sticky='ew', padx=5, pady=5)\n        self.progress_bar['value'] = 0\n        \n        def cleanup_thread():\n            deleted_files = deleted_size = 0\n            errors = []\n            \n            for i, path in enumerate(enabled_paths):\n                # Раскрываем переменные окружения в пути\n                expanded_path = self.expand_windows_path(path)\n                if not os.path.exists(expanded_path):\n                    continue\n                \n                try:\n                    # Если путь заканчивается звездочкой, удаляем все файлы в директории\n                    if expanded_path.endswith('*'):\n                        expanded_path = expanded_path[:-1]  # Убираем звездочку\n                        if not os.path.exists(expanded_path):\n                            continue\n                        \n                        # Удаляем все файлы в директории\n                        for root, dirs, files in os.walk(expanded_path, followlinks=False):\n                            dirs[:] = [d for d in dirs if not os.path.islink(os.path.join(root, d))]\n                            \n                            for file in files:\n                                try:\n                                    file_path = os.path.join(root, file)\n                                    if not os.path.islink(file_path) and os.path.exists(file_path):\n                                        size = os.path.getsize(file_path)\n                                        os.remove(file_path)\n                                        deleted_files += 1\n                                        deleted_size += size\n                                except (OSError, PermissionError) as e:\n                                    errors.append(f\"{file_path}: {str(e)}\")\n                        \n                            for dir_name in dirs:\n                                try:\n                                    dir_path = os.path.join(root, dir_name)\n                                    if os.path.exists(dir_path) and not os.listdir(dir_path):\n                                        os.rmdir(dir_path)\n                                except (OSError, PermissionError):\n                                    pass\n                    else:\n                        # Удаляем файлы по конкретному пути\n                        for root, dirs, files in os.walk(expanded_path, followlinks=False):\n                            dirs[:] = [d for d in dirs if not os.path.islink(os.path.join(root, d))]\n                            \n                            for file in files:\n                                try:\n                                    file_path = os.path.join(root, file)\n                                    if not os.path.islink(file_path) and os.path.exists(file_path):\n                                        size = os.path.getsize(file_path)\n                                        os.remove(file_path)\n                                        deleted_files += 1\n                                        deleted_size += size\n                                except (OSError, PermissionError) as e:\n                                    errors.append(f\"{file_path}: {str(e)}\")\n                        \n                            for dir_name in dirs:\n                                try:\n                                    dir_path = os.path.join(root, dir_name)\n                                    if os.path.exists(dir_path) and not os.listdir(dir_path):\n                                        os.rmdir(dir_path)\n                                except (OSError, PermissionError):\n                                    pass\n                \n                except (OSError, PermissionError) as e:\n                    errors.append(f\"{expanded_path}: {str(e)}\")\n                \n                self.progress_bar['value'] = ((i + 1) / len(enabled_paths)) * 100\n                self.root.update_idletasks()\n            \n            self.progress_bar.grid_remove()\n            \n            message = f\"Очистка завершена!\\nУдалено файлов: {deleted_files}\\nОсвобождено: {self.format_size(deleted_size)}\"\n            \n            if errors and len(errors) <= 10:\n                message += f\"\\n\\nОшибки:\\n\" + \"\\n\".join(errors)\n            elif errors:\n                message += f\"\\n\\nОшибок: {len(errors)} (слишком много для отображения)\"\n            \n            messagebox.showinfo(\"Результат\", message)\n            self.refresh_info()\n        \n        Thread(target=cleanup_thread, daemon=True).start()\n    \n    def refresh_info(self):\n        for data in self.paths_data.values():\n            data['size'] = 0\n            data['count'] = 0\n        self.update_paths_info()\n        self.update_disk_info()\n    \n    def setup_gui(self):\n        self.root = IconTk()\n        self.root.title(\"Очистка временных файлов - Администратор\")\n        \n        # Настройка геометрии окна\n        self.config_manager = ConfigManager()\n        saved_geometry = self.config_manager.get_window_geometry('main')\n        if saved_geometry:\n            self.root.geometry(f\"{saved_geometry['width']}x{saved_geometry['height']}+{saved_geometry['x']}+{saved_geometry['y']}\")\n        else:\n            self.root.geometry(\"1100x600\")\n        \n        self.root.minsize(1100, 600)\n        self.root.update_idletasks()\n        \n        # Привязываем сохранение геометрии\n        self.root.bind('<Configure>', self.on_window_configure)\n        self.root.protocol(\"WM_DELETE_WINDOW\", self.on_closing)\n        \n        main_frame = ttk.Frame(self.root)\n        main_frame.pack(fill='both', expand=True, padx=10, pady=10)\n        \n        # Горизонтальный контейнер для блока дисков и надписи\n        disk_row_frame = ttk.Frame(main_frame)\n        disk_row_frame.pack(fill='x', padx=(10, 10), pady=(0, 10))\n        disk_frame = ttk.LabelFrame(disk_row_frame, text=\"Информация о дисках\")\n        disk_frame.pack(side='left', fill='x', expand=True)\n        disk_columns = ('Диск', 'Общий объем', 'Занято', 'Будет удалено', 'Свободно', 'Временные файлы')\n        self.disk_tree = ttk.Treeview(disk_frame, columns=disk_columns, show='headings', height=4)\n        # Устанавливаю ширину для каждого столбца\n        self.disk_tree.column('Диск', width=40)\n        self.disk_tree.column('Общий объем', width=80)\n        self.disk_tree.column('Занято', width=50)\n        self.disk_tree.column('Будет удалено', width=80)\n        self.disk_tree.column('Свободно', width=50)\n        self.disk_tree.column('Временные файлы', width=200)\n        \n        for col in disk_columns:\n            self.disk_tree.heading(col, text=col)\n            self.disk_tree.column(col, width=120)\n        \n        disk_scrollbar = ttk.Scrollbar(disk_frame, orient='vertical', command=self.disk_tree.yview)\n        self.disk_tree.configure(yscrollcommand=disk_scrollbar.set)\n        \n        self.disk_tree.pack(side='left', fill='both', expand=True)\n        disk_scrollbar.pack(side='right', fill='y')\n        \n        # Блок справа от disk_frame\n        disk_info_side = ttk.Frame(disk_row_frame)\n        disk_info_side.pack(side='right', fill='y', padx=(5, 5), pady=5)\n        label_will_delete = ttk.Label(disk_info_side, text=\"Сотрётся\", font=(\"Segoe UI\", 18, \"bold\"))\n        label_will_delete.pack(anchor='n', pady=(10, 5))\n        self.label_total_to_delete = ttk.Label(disk_info_side, text=\"0 B\", font=(\"Segoe UI\", 14))\n        self.label_total_to_delete.pack(anchor='n')\n        \n        # Меню выбора списка и кнопки\n        top_frame = ttk.Frame(main_frame)\n        top_frame.pack(fill='x', pady=(0, 5))\n        \n        # Кнопка \"Выбрать все\" слева\n        self.toggle_all_state = tk.BooleanVar(value=True)  # True = выбрать все, False = снять все\n        def toggle_all_action():\n            enable = self.toggle_all_state.get()\n            self.toggle_all_paths(enable)\n            self.toggle_all_state.set(not enable)\n            if enable:\n                toggle_btn.config(text=\"❎\")\n            else:\n                toggle_btn.config(text=\"✅\")\n        toggle_btn = ttk.Button(top_frame, text=\"✅\", command=toggle_all_action)\n        toggle_btn.pack(side='left', padx=(0,20))\n        \n\n        # Кнопка переименования\n        ttk.Button(top_frame, text='Удалить список', command=self.delete_current_list).pack(side='right', padx=2)\n        ttk.Button(top_frame, text='Переименовать', command=self.rename_current_list).pack(side='right', padx=2)\n        ttk.Button(top_frame, text='Новый список', command=self.create_new_list).pack(side='right', padx=2)\n\n        self.lists_var = tk.StringVar()\n        self.lists_menu = ttk.Combobox(top_frame, textvariable=self.lists_var, state='readonly', width=30)\n        self.lists_menu.pack(side='right', padx=(0, 5))\n        self.lists_menu.bind('<<ComboboxSelected>>', lambda e: self.switch_list_by_display(self.lists_var.get()))\n        self.update_lists_menu()\n        # Пути для очистки\n        paths_frame = ttk.LabelFrame(main_frame, text=\"Пути для очистки (Клик по статусу - переключение, двойной клик по комментарию - редактирование)\")\n        paths_frame.pack(fill='both', expand=True, pady=(0, 10))\n        \n        # Список путей\n        paths_columns = ('Статус', 'Комментарий', 'Путь', 'Размер', 'Файлов')\n        self.paths_tree = ttk.Treeview(paths_frame, columns=paths_columns, show='headings')\n        for i, col in enumerate(paths_columns):\n            self.paths_tree.heading(f'#{i+1}', text=col, \n                                  command=lambda c=f'#{i+1}': self.sort_column(c, False))\n        self.paths_tree.column('#1', width=100)   # Статус\n        self.paths_tree.column('#2', width=150)  # Комментарий\n        self.paths_tree.column('#3', width=200)  # Путь\n        self.paths_tree.column('#4', width=60)  # Размер\n        self.paths_tree.column('#5', width=60)   # Файлов\n        self.paths_tree.tag_configure('enabled', background='#b6fcb6')  # ярко-зелёный\n        self.paths_tree.tag_configure('disabled', background='#fcb6b6')  # ярко-красный\n        self.paths_tree.bind('<Button-1>', self.on_path_click)\n        self.paths_tree.bind('<Double-1>', self.on_path_double_click)\n        paths_scrollbar_v = ttk.Scrollbar(paths_frame, orient='vertical', command=self.paths_tree.yview)\n        self.paths_tree.configure(yscrollcommand=paths_scrollbar_v.set)\n        self.paths_tree.grid(row=1, column=0, sticky='nsew')\n        paths_scrollbar_v.grid(row=1, column=1, sticky='ns')\n        paths_frame.grid_rowconfigure(1, weight=1)\n        paths_frame.grid_columnconfigure(0, weight=1)\n\n        # Вертикальный фрейм для кнопок справа от списка путей\n        right_btns_frame = ttk.Frame(paths_frame)\n        right_btns_frame.grid(row=1, column=2, rowspan=2, sticky='ns', padx=(10,10), pady=(5,5))\n        ttk.Button(right_btns_frame, text=\"Добавить путь\", command=self.add_custom_path).pack(fill='x', pady=2)\n        ttk.Button(right_btns_frame, text=\"Удалить путь\", command=self.remove_custom_path).pack(fill='x', pady=2)\n        ttk.Button(right_btns_frame, text=\"Обновить\", command=self.refresh_info).pack(fill='x', pady=2)\n        ttk.Button(right_btns_frame, text=\"Открыть редактор\", command=self.open_config_editor).pack(fill='x', pady=2)\n        ttk.Button(right_btns_frame, text=\"Начать чистку\", command=self.clean_temp_files).pack(side='bottom', fill='x', pady=2)\n\n\n        # Информация и кнопки\n        info_frame = ttk.Frame(main_frame)\n        info_frame.pack(fill='x')\n        \n        self.total_size_label = ttk.Label(info_frame, text=\"Общий объем: Вычисляется...\")\n        self.total_size_label.grid(row=0, column=0, sticky='w', padx=(0, 20))\n        \n        self.total_files_label = ttk.Label(info_frame, text=\"Файлов: Вычисляется...\")\n        self.total_files_label.grid(row=1, column=0, sticky='w', padx=(0, 20))\n        \n        self.progress_bar = ttk.Progressbar(info_frame, mode='determinate')\n        \n        info_frame.grid_columnconfigure(0, weight=1)\n        \n        # Статус бар\n        status_frame = ttk.Frame(main_frame)\n        status_frame.pack(fill='x', pady=(5, 0))\n        \n        self.status_var = tk.StringVar()\n        self.status_var.set(\"Готово\")\n        status_label = ttk.Label(status_frame, textvariable=self.status_var, relief='sunken', anchor='w')\n        status_label.pack(fill='x', padx=(10, 100), pady=2)\n        \n        self.root.after(100, self.refresh_info)\n        \n        # Кнопки в нижнем правом углу\n        buttons_frame = ttk.Frame(self.root)\n        buttons_frame.place(relx=1.0, rely=1.0, anchor='se', x=-10, y=-10)\n        \n        # Кнопка помощи\n        help_btn = ttk.Button(buttons_frame, text=\"❔\", command=self.show_help)\n        help_btn.pack(side='left', padx=5)\n        \n        # Кнопка контакта разработчика\n        dev_btn = ttk.Button(buttons_frame, text=\"📞\", command=self.open_telegram)\n        dev_btn.pack(side='left')\n        \n        # Всплывающие подсказки\n        def show_tooltip(event, text):\n            btn = event.widget\n            btn.tooltip = tk.Toplevel(btn)\n            btn.tooltip.wm_overrideredirect(True)\n            x = btn.winfo_rootx() - 60\n            y = btn.winfo_rooty() - 30\n            btn.tooltip.wm_geometry(f\"+{x}+{y}\")\n            label = tk.Label(btn.tooltip, text=text, bg=\"#333\", fg=\"#fff\", padx=8, pady=4, relief=\"solid\", borderwidth=1)\n            label.pack()\n        \n        def hide_tooltip(event):\n            btn = event.widget\n            if hasattr(btn, 'tooltip'):\n                btn.tooltip.destroy()\n                del btn.tooltip\n        \n        help_btn.bind(\"<Enter>\", lambda e: show_tooltip(e, \"Справка\"))\n        help_btn.bind(\"<Leave>\", hide_tooltip)\n        dev_btn.bind(\"<Enter>\", lambda e: show_tooltip(e, \"Контакт разработчика\"))\n        dev_btn.bind(\"<Leave>\", hide_tooltip)\n    \n    def on_window_configure(self, event):\n        if event.widget == self.root:\n            geometry = {\n                'width': self.root.winfo_width(),\n                'height': self.root.winfo_height(),\n                'x': self.root.winfo_x(),\n                'y': self.root.winfo_y()\n            }\n            self.config_manager.save_window_geometry('main', geometry)\n    \n    def on_closing(self):\n        geometry = {\n            'width': self.root.winfo_width(),\n            'height': self.root.winfo_height(),\n            'x': self.root.winfo_x(),\n            'y': self.root.winfo_y()\n        }\n        self.config_manager.save_window_geometry('main', geometry)\n        self.root.destroy()\n    \n    def open_config_editor(self):\n        # Если редактор уже открыт, закрываем его\n        if self.editor_window is not None:\n            self.close_editor()\n            return\n            \n        editor = IconToplevel(self.root)\n        self.editor_window = editor\n        editor.title(\"Редактор списка путей\")\n        \n        # Настройка геометрии окна редактора\n        saved_geometry = self.config_manager.get_window_geometry('editor')\n        if saved_geometry:\n            editor.geometry(f\"{saved_geometry['width']}x{saved_geometry['height']}+{saved_geometry['x']}+{saved_geometry['y']}\")\n        else:\n            editor.geometry(\"1000x500\")\n        \n        editor.minsize(800, 400)\n        editor.update_idletasks()\n        \n        # Привязываем сохранение геометрии\n        editor.bind('<Configure>', lambda e: self.on_editor_configure(e, editor))\n        editor.protocol(\"WM_DELETE_WINDOW\", self.close_editor)\n       \n        # Кнопка сохранить в верхнем правом углу\n        def save():\n            try:\n                with open(self.config_file, 'w', encoding='utf-8') as f:\n                    f.write(text.get('1.0', 'end').rstrip())\n                self.load_config()\n                self.refresh_info()\n                self.editor_has_changes = False\n                self.close_editor()\n            except Exception as e:\n                messagebox.showerror(\"Ошибка\", f\"Не удалось сохранить файл: {e}\")\n                \n        save_btn = ttk.Button(editor, text=\"Сохранить\", command=save)\n        save_btn.pack(anchor='nw', padx=10, pady=5)\n         \n        # Надпись с обозначением синтаксиса и примером\n        syntax_frame = ttk.Frame(editor)\n        syntax_frame.pack(anchor='nw', padx=10, pady=(0, 5))\n        syntax_label = ttk.Label(syntax_frame, text=\"Синтаксис: путь | статус (+/-) | комментарий (скрытая заметка)\", font=(\"Segoe UI\", 10, \"italic\"), foreground=\"#555\")\n        syntax_label.pack(anchor='w')\n        example_label = ttk.Label(syntax_frame, text=\"Пример: C:/Temp|+|Временные файлы Windows (скрытая заметка)\", font=(\"Segoe UI\", 10), foreground=\"#888\")\n        example_label.pack(anchor='w')\n        example_label = ttk.Label(syntax_frame, text=\"Особенность: Ctrl+X/C/V - работает с английской раскладкой\", font=(\"Segoe UI\", 10), foreground=\"#888\")\n        example_label.pack(anchor='w')\n        \n        # Текстовый редактор\n        text = tk.Text(editor, font=(\"Consolas\", 12), wrap='none')\n        self.editor_text = text\n        text.pack(fill='both', expand=True, padx=10, pady=10)\n        # Скроллбары\n        yscroll = ttk.Scrollbar(editor, orient='vertical', command=text.yview)\n        yscroll.pack(side='right', fill='y')\n        text.configure(yscrollcommand=yscroll.set)\n        xscroll = ttk.Scrollbar(editor, orient='horizontal', command=text.xview)\n        xscroll.pack(side='bottom', fill='x')\n        text.configure(xscrollcommand=xscroll.set)\n        # Загрузка файла\n        try:\n            with open(self.config_file, 'r', encoding='utf-8') as f:\n                content = f.read()\n        except Exception as e:\n            content = ''\n        text.insert('1.0', content)\n        self.editor_has_changes = False\n        \n        # Подсветка синтаксиса\n        def highlight():\n            text.tag_remove('path', '1.0', 'end')\n            text.tag_remove('status', '1.0', 'end')\n            text.tag_remove('comment', '1.0', 'end')\n            text.tag_remove('hidden_note', '1.0', 'end')\n            for i, line in enumerate(text.get('1.0', 'end').splitlines()):\n                start = f\"{i+1}.0\"\n                if '|' in line:\n                    parts = line.split('|', 2)\n                    if len(parts) > 0:\n                        end1 = f\"{i+1}.{len(parts[0])}\"\n                        text.tag_add('path', start, end1)\n                    if len(parts) > 1:\n                        start2 = f\"{i+1}.{len(parts[0])+1}\"\n                        end2 = f\"{i+1}.{len(parts[0])+2}\"\n                        text.tag_add('status', start2, end2)\n                    if len(parts) > 2:\n                        comment = parts[2]\n                        if \"(\" in comment and \")\" in comment:\n                            start_bracket = comment.find(\"(\")\n                            end_bracket = comment.find(\")\")\n                            if start_bracket != -1 and end_bracket != -1 and end_bracket > start_bracket:\n                                # Подсветка комментария до скобок\n                                comment_text = comment[:start_bracket].strip()\n                                start3 = f\"{i+1}.{len(parts[0])+3}\"\n                                end3 = f\"{i+1}.{len(parts[0])+3+len(comment_text)}\"\n                                text.tag_add('comment', start3, end3)\n                                \n                                # Подсветка скрытой заметки (включая скобки)\n                                start4 = f\"{i+1}.{len(parts[0])+3+start_bracket}\"\n                                end4 = f\"{i+1}.{len(parts[0])+3+end_bracket+1}\"  # +1 чтобы включить закрывающую скобку\n                                text.tag_add('hidden_note', start4, end4)\n                        else:\n                            start3 = f\"{i+1}.{len(parts[0])+3}\"\n                            end3 = f\"{i+1}.{len(line)}\"\n                            text.tag_add('comment', start3, end3)\n            \n        text.tag_configure('path', foreground='#007acc')\n        text.tag_configure('status', foreground='#e81123', font=(\"Consolas\", 12, \"bold\"))\n        text.tag_configure('comment', foreground='#228B22')\n        text.tag_configure('hidden_note', foreground='#666666', font=(\"Consolas\", 12, \"italic\"))\n        highlight()\n        \n        def on_text_change(event):\n            self.editor_has_changes = True\n            highlight()\n        \n        text.bind('<KeyRelease>', on_text_change)\n    \n    def close_editor(self):\n        if self.editor_window is None:\n            return\n            \n        if self.editor_has_changes:\n            response = messagebox.askyesnocancel(\n                \"Сохранение изменений\",\n                \"В списке есть несохраненные изменения. Сохранить?\",\n                icon='question'\n            )\n            \n            if response is None:  # Cancel\n                return\n            elif response:  # Yes\n                try:\n                    with open(self.config_file, 'w', encoding='utf-8') as f:\n                        f.write(self.editor_text.get('1.0', 'end').rstrip())\n                    self.load_config()\n                    self.refresh_info()\n                except Exception as e:\n                    messagebox.showerror(\"Ошибка\", f\"Не удалось сохранить файл: {e}\")\n                    return\n        \n        # Сохраняем геометрию перед закрытием\n        geometry = {\n            'width': self.editor_window.winfo_width(),\n            'height': self.editor_window.winfo_height(),\n            'x': self.editor_window.winfo_x(),\n            'y': self.editor_window.winfo_y()\n        }\n        self.config_manager.save_window_geometry('editor', geometry)\n        \n        self.editor_window.destroy()\n        self.editor_window = None\n        self.editor_text = None\n        self.editor_has_changes = False\n    \n    def on_editor_configure(self, event, editor):\n        if event.widget == editor:\n            geometry = {\n                'width': editor.winfo_width(),\n                'height': editor.winfo_height(),\n                'x': editor.winfo_x(),\n                'y': editor.winfo_y()\n            }\n            self.config_manager.save_window_geometry('editor', geometry)\n    \n    def get_list_files(self):\n        return [f for f in os.listdir(self.lists_dir) if f.endswith('.txt')]\n\n    def get_last_active_list(self):\n        config = configparser.ConfigParser()\n        if os.path.exists(self.ini_file):\n            config.read(self.ini_file, encoding='utf-8')\n            if 'main' in config and 'active' in config['main']:\n                fname = config['main']['active']\n                fpath = os.path.join(self.lists_dir, fname)\n                if os.path.exists(fpath):\n                    return fpath\n        # Если нет ini или файла, создаём дефолтный\n        default = os.path.join(self.lists_dir, 'default.txt')\n        if not os.path.exists(default):\n            with open(default, 'w', encoding='utf-8') as f:\n                f.write('')\n        self.save_active_list('default.txt')\n        return default\n\n    def save_active_list(self, fname):\n        config = configparser.ConfigParser()\n        config['main'] = {'active': fname}\n        with open(self.ini_file, 'w', encoding='utf-8') as f:\n            config.write(f)\n\n    def switch_list(self, fname):\n        self.config_file = os.path.join(self.lists_dir, fname)\n        self.save_active_list(fname)\n        self.load_config()\n        self.refresh_info()\n        # Сбросить состояние кнопки при смене списка\n        if hasattr(self, 'toggle_all_state'):\n            self.toggle_all_state.set(True)\n            if hasattr(self, 'toggle_btn'):\n                self.toggle_btn.config(text=\"✅\")\n\n    def create_new_list(self):\n        import datetime\n        base = 'list_' + datetime.datetime.now().strftime('%Y%m%d_%H%M%S') + '.txt'\n        fpath = os.path.join(self.lists_dir, base)\n        with open(fpath, 'w', encoding='utf-8') as f:\n            f.write('')\n        self.switch_list(base)\n        self.update_lists_menu()\n\n    def delete_current_list(self):\n        fname = os.path.basename(self.config_file)\n        if not fname:\n            messagebox.showwarning('Внимание', 'Нельзя удалить стандартный список!')\n            return\n        if not messagebox.askyesno('Подтверждение', f'Удалить список {fname}?'):\n            return\n        os.remove(self.config_file)\n        # Переключаемся на default\n        self.switch_list('default.txt')\n        self.update_lists_menu()\n\n    def update_lists_menu(self):\n        files = self.get_list_files()\n        # Сохраняем соответствие отображаемое имя <-> файл\n        self.display_to_file = {os.path.splitext(f)[0]: f for f in files}\n        display_names = list(self.display_to_file.keys())\n        # Текущее имя без расширения\n        current_file = os.path.basename(self.config_file)\n        current_display = os.path.splitext(current_file)[0]\n        self.lists_var.set(current_display)\n        self.lists_menu['values'] = display_names\n    \n    def switch_list_by_display(self, display_name):\n        # По отображаемому имени ищем файл\n        fname = self.display_to_file.get(display_name)\n        if fname:\n            self.switch_list(fname)\n\n    def rename_current_list(self):\n        fname = os.path.basename(self.config_file)\n        old_display = os.path.splitext(fname)[0]\n        \n        rename_window = IconToplevel(self.root)\n        rename_window.title(\"Переименование списка\")\n        rename_window.geometry(\"300x100\")\n        rename_window.transient(self.root)\n        rename_window.grab_set()\n        \n        tk.Label(rename_window, text=\"Новое имя списка:\").pack(pady=5)\n        entry = tk.Entry(rename_window, width=40)\n        entry.pack(pady=5, padx=10, fill='x')\n        entry.insert(0, old_display)\n        entry.select_range(0, tk.END)\n        entry.focus()\n        \n        def do_rename():\n            new_name = entry.get().strip()\n            if not new_name or new_name == old_display:\n                rename_window.destroy()\n                return\n                \n            # Проверка на конфликт\n            new_fname = new_name + '.txt'\n            new_path = os.path.join(self.lists_dir, new_fname)\n            if os.path.exists(new_path):\n                messagebox.showerror('Ошибка', 'Список с таким именем уже существует!')\n                return\n                \n            try:\n                os.rename(self.config_file, new_path)\n                self.switch_list(new_fname)\n                self.update_lists_menu()\n                rename_window.destroy()\n            except Exception as e:\n                messagebox.showerror('Ошибка', f'Не удалось переименовать: {e}')\n        \n        button_frame = tk.Frame(rename_window)\n        button_frame.pack(pady=10)\n        tk.Button(button_frame, text=\"Сохранить\", command=do_rename).pack(side='left', padx=5)\n        tk.Button(button_frame, text=\"Отмена\", command=rename_window.destroy).pack(side='left', padx=5)\n        \n        entry.bind('<Return>', lambda e: do_rename())\n        entry.bind('<Escape>', lambda e: rename_window.destroy())\n        rename_window.protocol(\"WM_DELETE_WINDOW\", rename_window.destroy)\n    \n    def show_help(self):\n        try:\n            help_path = resource_path('info.html')\n            if os.path.exists(help_path):\n                webbrowser.open(help_path)\n            else:\n                messagebox.showerror(\"Ошибка\", \"Файл справки не найден\")\n        except Exception as e:\n            messagebox.showerror(\"Ошибка\", f\"Не удалось открыть справку: {e}\")\n    \n    def run(self):\n        try:\n            self.root.mainloop()\n        finally:\n            self.executor.shutdown(wait=False)\n\nif __name__ == \"__main__\":\n    app = TempCleaner()\n    app.run()",
