  "scripts": [
    {
      "code": "#!/usr/bin/env python3\n\"\"\"\nIMAGE FORMAT CONVERTER\nКонвертер форматов изображений — двойной клик для запуска\n\"\"\"\n\nimport os\nimport sys\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom collections import defaultdict\n\n\n# ══════════════════════════════════════════════════════\n#  Авто-установка зависимостей\n# ══════════════════════════════════════════════════════\n\ndef install_package(package: str, import_name: str = None):\n    if import_name is None:\n        import_name = package\n    try:\n        __import__(import_name)\n        return True\n    except ImportError:\n        print(f\"  [!] Устанавливаю {package}...\")\n        try:\n            subprocess.check_call(\n                [sys.executable, \"-m\", \"pip\", \"install\", package, \"--quiet\"],\n                stdout=subprocess.DEVNULL,\n                stderr=subprocess.DEVNULL,\n            )\n            print(f\"  [+] {package} установлен успешно.\")\n            return True\n        except subprocess.CalledProcessError:\n            print(f\"  [X] Не удалось установить {package}.\")\n            return False\n\n\nprint(\"  Проверка зависимостей...\")\ninstall_package(\"rich\")\n\n# Пробуем OpenImageIO — если не вышло, предложим Pillow как запасной вариант\nHAS_OIIO = install_package(\"OpenImageIO\")\nHAS_PILLOW = False\nif not HAS_OIIO:\n    print(\"  [!] OpenImageIO недоступен. Пробую Pillow как альтернативу...\")\n    HAS_PILLOW = install_package(\"Pillow\", \"PIL\")\n\n# ══════════════════════════════════════════════════════\n#  Импорты после установки\n# ══════════════════════════════════════════════════════\n\nfrom rich.console import Console\nfrom rich.panel import Panel\nfrom rich.table import Table\nfrom rich.progress import Progress, BarColumn, TextColumn, TimeRemainingColumn, SpinnerColumn\nfrom rich.prompt import Prompt, IntPrompt\nfrom rich.rule import Rule\nfrom rich import box\nfrom rich.padding import Padding\nfrom rich.align import Align\n\nconsole = Console(highlight=False)\n\n# ══════════════════════════════════════════════════════\n#  Данные форматов\n# ══════════════════════════════════════════════════════\n\nSUPPORTED_READ = {\n    \".tx\", \".tif\", \".tiff\", \".exr\", \".hdr\", \".png\", \".jpg\", \".jpeg\",\n    \".bmp\", \".tga\", \".psd\", \".dpx\", \".jp2\", \".webp\", \".gif\", \".ico\",\n    \".dds\", \".ktx\", \".ptex\",\n}\n\n# Цветные метки ASCII (нет emoji → нет проблем с шириной в Windows)\nFORMAT_COLOR = {\n    \".tx\":   (\"bright_magenta\", \"TX \"),\n    \".tif\":  (\"bright_blue\",    \"TIF\"),\n    \".tiff\": (\"bright_blue\",    \"TIF\"),\n    \".exr\":  (\"bright_yellow\",  \"EXR\"),\n    \".hdr\":  (\"yellow\",         \"HDR\"),\n    \".png\":  (\"bright_green\",   \"PNG\"),\n    \".jpg\":  (\"bright_red\",     \"JPG\"),\n    \".jpeg\": (\"bright_red\",     \"JPG\"),\n    \".bmp\":  (\"white\",          \"BMP\"),\n    \".tga\":  (\"magenta\",        \"TGA\"),\n    \".psd\":  (\"bright_cyan\",    \"PSD\"),\n    \".dpx\":  (\"cyan\",           \"DPX\"),\n    \".jp2\":  (\"red\",            \"JP2\"),\n    \".webp\": (\"bright_magenta\", \"WBP\"),\n    \".gif\":  (\"bright_green\",   \"GIF\"),\n    \".ico\":  (\"bright_cyan\",    \"ICO\"),\n    \".dds\":  (\"yellow\",         \"DDS\"),\n    \".ktx\":  (\"bright_yellow\",  \"KTX\"),\n}\n\nWRITE_FORMATS = [\n    {\"ext\": \".jpg\",  \"label\": \"JPG  - JPEG, для веба и фото\",         \"color\": \"bright_red\"},\n    {\"ext\": \".png\",  \"label\": \"PNG  - без потерь, с прозрачностью\",   \"color\": \"bright_green\"},\n    {\"ext\": \".tiff\", \"label\": \"TIFF - профессиональный, без потерь\",  \"color\": \"bright_blue\"},\n    {\"ext\": \".exr\",  \"label\": \"EXR  - HDR, для VFX и рендера\",        \"color\": \"bright_yellow\"},\n    {\"ext\": \".bmp\",  \"label\": \"BMP  - несжатый Windows формат\",       \"color\": \"white\"},\n    {\"ext\": \".tga\",  \"label\": \"TGA  - Targa, для игр и текстур\",      \"color\": \"magenta\"},\n    {\"ext\": \".webp\", \"label\": \"WEBP - современный веб-формат\",        \"color\": \"bright_magenta\"},\n    {\"ext\": \".hdr\",  \"label\": \"HDR  - Radiance HDR, для окружений\",   \"color\": \"yellow\"},\n]\n\n# Пиллоу поддерживает подмножество форматов\nPILLOW_WRITE = {\".jpg\", \".png\", \".tiff\", \".bmp\", \".tga\", \".webp\", \".gif\"}\nPILLOW_READ  = {\".jpg\", \".jpeg\", \".png\", \".tiff\", \".tif\", \".bmp\",\n                \".tga\", \".webp\", \".gif\", \".ico\", \".psd\"}\n\n\n# ══════════════════════════════════════════════════════\n#  Шапка\n# ══════════════════════════════════════════════════════\n\ndef print_header():\n    console.clear()\n    # Фиксированная ширина 52 симв, только ASCII + безопасные box-символы\n    console.print()\n    console.print(\"  [bold bright_cyan]\" + \"=\" * 52 + \"[/]\")\n    console.print(\"  [bold bright_cyan]|[/]  [bold white]IMAGE FORMAT CONVERTER[/]\"\n                  \"  [dim]|  Конвертер v2.1[/]  [bold bright_cyan]|[/]\")\n    console.print(\"  [bold bright_cyan]\" + \"=\" * 52 + \"[/]\")\n    console.print()\n    # Бэкенд\n    if HAS_OIIO:\n        backend = \"[bold bright_green]OpenImageIO[/] [dim](все форматы)[/]\"\n    elif HAS_PILLOW:\n        backend = \"[bold bright_yellow]Pillow[/] [dim](JPG PNG TIFF BMP TGA WEBP)[/]\"\n    else:\n        backend = \"[bold red]нет бэкенда — конвертация недоступна[/]\"\n    console.print(f\"  [dim]Бэкенд:[/] {backend}\")\n    console.print()\n\n\n# ══════════════════════════════════════════════════════\n#  Цветная метка формата (ASCII, без emoji)\n# ══════════════════════════════════════════════════════\n\ndef fmt_badge(ext: str) -> str:\n    color, label = FORMAT_COLOR.get(ext.lower(), (\"white\", ext.upper()[:3].ljust(3)))\n    return f\"[bold {color}][{label}][/]\"\n\n\n# ══════════════════════════════════════════════════════\n#  Сканирование папки\n# ══════════════════════════════════════════════════════\n\ndef scan_directory(directory: str) -> dict:\n    found = defaultdict(list)\n    for f in Path(directory).iterdir():\n        if f.is_file():\n            ext = f.suffix.lower()\n            if ext in SUPPORTED_READ:\n                found[ext].append(str(f))\n    return dict(found)\n\n\n# ══════════════════════════════════════════════════════\n#  Шаг 1: выбор исходного формата\n# ══════════════════════════════════════════════════════\n\ndef choose_source_format(found: dict) -> tuple:\n    console.print(Rule(\"[bold bright_yellow] ШАГ 1  Выберите исходный формат [/]\",\n                       style=\"bright_yellow\"))\n    console.print()\n\n    table = Table(box=box.SIMPLE_HEAD, border_style=\"bright_cyan\",\n                  show_header=True, header_style=\"bold bright_cyan\",\n                  padding=(0, 1), show_edge=True)\n    table.add_column(\" #\", style=\"bold bright_yellow\", width=4, justify=\"right\")\n    table.add_column(\"Формат\", width=9)\n    table.add_column(\"Файлов\", style=\"cyan\", width=8, justify=\"right\")\n    table.add_column(\"Пример файла\", style=\"dim white\")\n\n    exts = sorted(found.keys())\n    for i, ext in enumerate(exts, 1):\n        files = found[ext]\n        example = Path(files[0]).name if files else \"-\"\n        if len(example) > 38:\n            example = example[:35] + \"...\"\n        table.add_row(str(i), fmt_badge(ext), str(len(files)), example)\n\n    console.print(Padding(table, (0, 2)))\n    console.print()\n\n    choice = IntPrompt.ask(\n        f\"  [bold bright_yellow]Введите номер[/] [dim](1-{len(exts)})[/]\",\n        default=1\n    )\n    choice = max(1, min(choice, len(exts)))\n    chosen_ext = exts[choice - 1]\n    files = found[chosen_ext]\n\n    console.print(\n        f\"\\n  [bright_green]OK[/] Выбран {fmt_badge(chosen_ext)} \"\n        f\"[dim]—[/] [bold]{len(files)}[/] файлов\\n\"\n    )\n    return chosen_ext, files\n\n\n# ══════════════════════════════════════════════════════\n#  Шаг 2: выбор целевого формата\n# ══════════════════════════════════════════════════════\n\ndef choose_target_format(source_ext: str) -> dict | None:\n    console.print(Rule(\"[bold bright_yellow] ШАГ 2  Выберите целевой формат [/]\",\n                       style=\"bright_yellow\"))\n    console.print()\n\n    # Фильтр по бэкенду и убираем исходный формат\n    available = []\n    for fmt in WRITE_FORMATS:\n        if fmt[\"ext\"] == source_ext:\n            continue\n        if not HAS_OIIO and HAS_PILLOW and fmt[\"ext\"] not in PILLOW_WRITE:\n            continue\n        available.append(fmt)\n\n    if not available:\n        console.print(\"  [red]Нет доступных форматов для конвертации.[/]\")\n        return None\n\n    table = Table(box=box.SIMPLE_HEAD, border_style=\"bright_cyan\",\n                  show_header=True, header_style=\"bold bright_cyan\",\n                  padding=(0, 1), show_edge=True)\n    table.add_column(\" #\", style=\"bold bright_yellow\", width=4, justify=\"right\")\n    table.add_column(\"Описание\", width=46)\n\n    for i, fmt in enumerate(available, 1):\n        color = fmt[\"color\"]\n        label = fmt[\"label\"]\n        table.add_row(str(i), f\"[bold {color}]{label}[/]\")\n\n    console.print(Padding(table, (0, 2)))\n    console.print()\n\n    choice = IntPrompt.ask(\n        f\"  [bold bright_yellow]Введите номер[/] [dim](1-{len(available)})[/]\",\n        default=1\n    )\n    choice = max(1, min(choice, len(available)))\n    fmt = available[choice - 1]\n\n    console.print(\n        f\"\\n  [bright_green]OK[/] Целевой формат: \"\n        f\"[bold {fmt['color']}]{fmt['ext'].upper()}[/]\\n\"\n    )\n    return fmt\n\n\n# ══════════════════════════════════════════════════════\n#  Конвертация через OpenImageIO\n# ══════════════════════════════════════════════════════\n\ndef convert_oiio(f_path: str, out_path: str) -> str | None:\n    import OpenImageIO as oiio\n    buf = oiio.ImageBuf(f_path)\n    if buf.has_error:\n        return buf.geterror()\n    ok = buf.write(out_path)\n    if not ok:\n        return buf.geterror()\n    return None\n\n\n# ══════════════════════════════════════════════════════\n#  Конвертация через Pillow\n# ══════════════════════════════════════════════════════\n\ndef convert_pillow(f_path: str, out_path: str) -> str | None:\n    from PIL import Image\n    try:\n        with Image.open(f_path) as img:\n            ext = Path(out_path).suffix.lower()\n            if ext in (\".jpg\", \".jpeg\") and img.mode in (\"RGBA\", \"P\", \"LA\"):\n                img = img.convert(\"RGB\")\n            img.save(out_path)\n        return None\n    except Exception as e:\n        return str(e)\n\n\n# ══════════════════════════════════════════════════════\n#  Шаг 3: запуск конвертации\n# ══════════════════════════════════════════════════════\n\ndef convert_files(files: list, target_fmt: dict, source_ext: str):\n    console.print(Rule(\"[bold bright_yellow] ШАГ 3  Конвертация [/]\",\n                       style=\"bright_yellow\"))\n    console.print()\n\n    if not HAS_OIIO and not HAS_PILLOW:\n        console.print(Panel(\n            \"[bold red]Нет доступного бэкенда для конвертации![/]\\n\\n\"\n            \"Установите одно из:\\n\"\n            \"  pip install OpenImageIO\\n\"\n            \"  pip install Pillow\\n\\n\"\n            \"OpenImageIO поддерживает TX, EXR, HDR и другие профессиональные форматы.\\n\"\n            \"Pillow — JPG, PNG, TIFF, BMP, TGA, WEBP.\",\n            title=\"[red]Ошибка[/]\", border_style=\"red\", box=box.ROUNDED\n        ))\n        return\n\n    converted = 0\n    errors = 0\n    error_log = []\n\n    with Progress(\n        SpinnerColumn(style=\"bright_cyan\"),\n        TextColumn(\"[progress.description]{task.description}\"),\n        BarColumn(bar_width=28, style=\"bright_cyan\", complete_style=\"bright_green\"),\n        TextColumn(\"[bold bright_yellow]{task.completed}/{task.total}[/]\"),\n        TimeRemainingColumn(),\n        console=console,\n        transient=False,\n    ) as progress:\n        task = progress.add_task(\n            f\"  {source_ext.upper()} -> {target_fmt['ext'].upper()}\",\n            total=len(files)\n        )\n\n        for f_path in sorted(files):\n            stem = Path(f_path).stem\n            out_path = str(Path(f_path).parent / (stem + target_fmt[\"ext\"]))\n\n            name_short = Path(f_path).name\n            if len(name_short) > 42:\n                name_short = name_short[:39] + \"...\"\n            progress.update(task, description=f\"  [dim]{name_short}[/]\")\n\n            # Выбираем бэкенд\n            err = None\n            if HAS_OIIO:\n                err = convert_oiio(f_path, out_path)\n            elif HAS_PILLOW:\n                if Path(f_path).suffix.lower() not in PILLOW_READ:\n                    err = f\"Pillow не поддерживает чтение {Path(f_path).suffix}\"\n                else:\n                    err = convert_pillow(f_path, out_path)\n\n            if err is None:\n                converted += 1\n            else:\n                error_log.append((Path(f_path).name, err))\n                errors += 1\n\n            progress.advance(task)\n            time.sleep(0.015)\n\n    # Итоги\n    console.print()\n    if converted:\n        console.print(Panel(\n            f\"[bold bright_green]Успешно конвертировано: {converted} файлов[/]\\n\"\n            f\"[dim]Формат: {target_fmt['ext'].upper()}  |  \"\n            f\"Папка: та же, что и оригиналы[/]\",\n            border_style=\"bright_green\", box=box.ROUNDED\n        ))\n\n    if error_log:\n        console.print()\n        err_table = Table(box=box.SIMPLE, show_header=True, header_style=\"bold red\")\n        err_table.add_column(\"Файл\", style=\"bold white\", max_width=30)\n        err_table.add_column(\"Ошибка\", style=\"dim red\", max_width=50)\n        for fname, emsg in error_log:\n            err_table.add_row(fname, emsg[:50])\n        console.print(Panel(\n            err_table,\n            title=f\"[bold red]Ошибок: {errors}[/]\",\n            border_style=\"red\"\n        ))\n\n\n# ══════════════════════════════════════════════════════\n#  Ещё раз?\n# ══════════════════════════════════════════════════════\n\ndef ask_again() -> bool:\n    console.print()\n    ans = Prompt.ask(\n        \"  [bold]Конвертировать ещё раз?[/] [dim](y/n)[/]\",\n        default=\"n\"\n    )\n    return ans.strip().lower() in (\"y\", \"yes\", \"д\", \"да\")\n\n\n# ══════════════════════════════════════════════════════\n#  Главная функция\n# ══════════════════════════════════════════════════════\n\ndef main():\n    print_header()\n\n    directory = os.path.dirname(os.path.abspath(__file__))\n    console.print(f\"  [dim]Папка:[/] [bold white]{directory}[/]\\n\")\n\n    while True:\n        found = scan_directory(directory)\n\n        if not found:\n            console.print(Panel(\n                \"[bold red]Поддерживаемые изображения не найдены![/]\\n\\n\"\n                f\"Положите файлы рядом со скриптом:\\n[bold]{directory}[/]\\n\\n\"\n                \"Форматы: TX  TIF  EXR  HDR  PNG  JPG  BMP  TGA  PSD  WEBP ...\",\n                border_style=\"red\", box=box.ROUNDED\n            ))\n            break\n\n        source_ext, files = choose_source_format(found)\n        console.print()\n        target_fmt = choose_target_format(source_ext)\n        if target_fmt is None:\n            break\n        console.print()\n        convert_files(files, target_fmt, source_ext)\n\n        if not ask_again():\n            break\n\n        print_header()\n        console.print(f\"  [dim]Папка:[/] [bold white]{directory}[/]\\n\")\n\n    # Пауза для двойного клика\n    console.print()\n    console.print(Rule(style=\"dim\"))\n    console.print(Align.center(\"[dim]Нажмите Enter для выхода[/]\"))\n    try:\n        input()\n    except (EOFError, KeyboardInterrupt):\n        pass\n\n\nif __name__ == \"__main__\":\n    try:\n        main()\n    except KeyboardInterrupt:\n        console.print(\"\\n\\n  [dim]Прервано.[/]\")\n        try:\n            input(\"\\n  Нажмите Enter для выхода...\")\n        except (EOFError, KeyboardInterrupt):\n            pass",
      "color": "rgb(255, 0, 77)",
      "created": "2026-06-01T05:18:50.151701",
      "description": "Конвертер форматов изображений",
      "folder_id": "c997c815",
